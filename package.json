{
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "engine:build": "pnpm --filter fraxel build",
    "engine:dev": "pnpm --filter fraxel dev",
    "demo:start": "pnpm --filter demo start",
    "demo:build": "pnpm --filter demo build",
    "demo:dev": "pnpm --filter demo dev",
    "dev": "concurrently \"pnpm engine:dev\" \"pnpm demo:dev\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  }
}
