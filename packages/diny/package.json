{
  "name": "tiny-engine",
  "version": "0.0.0",
  "type": "module",
  "description": "Declarative 2D game engine for the browser with JSX runtime and fine-grained reactivity",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./jsx-runtime": "./dist/jsx-runtime.js",
    "./jsx": "./dist/jsx/index.js",
    "./jsx/*": "./dist/jsx/*",
    "./hooks": "./dist/hooks/index.js",
    "./hooks/*": "./dist/hooks/*",
    "./scripts": "./dist/scripts/index.js",
    "./scripts/*": "./dist/scripts/*",
    "./*": "./dist/*"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "prepublishOnly": "pnpm build && pnpm -w lint"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "game-engine",
    "2d",
    "canvas",
    "jsx",
    "typescript",
    "signals",
    "reactivity",
    "browser"
  ],
  "author": "",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.29.3",
  "files": [
    "dist"
  ]
}
