{
  "name": "fraxel",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "A modern node-based 2D game engine for the web powered by JSX and fine-grained reactivity",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./jsx-runtime": "./dist/jsx-runtime.js",
    "./jsx": "./dist/jsx/index.js",
    "./jsx/*": "./dist/jsx/*",
    "./hooks": "./dist/hooks/index.js",
    "./hooks/*": "./dist/hooks/*",
    "./scripts": "./dist/scripts/index.js",
    "./scripts/*": "./dist/scripts/*",
    "./*": "./dist/*"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "prepublishOnly": "pnpm build && pnpm -w lint"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "game-engine",
    "2d",
    "canvas",
    "jsx",
    "typescript",
    "signals",
    "reactivity",
    "browser"
  ],
  "author": "José Sánchez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanchedev/fraxel.git"
  },
  "bugs": {
    "url": "https://github.com/sanchedev/fraxel/issues"
  },
  "homepage": "https://github.com/sanchedev/fraxel#readme",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.29.3",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
